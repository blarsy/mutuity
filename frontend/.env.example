NEXT_PUBLIC_GRAPHQL_URL=http://localhost:5050/graphql
NEXT_PUBLIC_BACKEND_URL=http://localhost:5050
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Optional explicit social provider start URLs.
# If omitted, frontend derives defaults from NEXT_PUBLIC_BACKEND_URL:
#   {BACKEND_URL}/auth/google/start and {BACKEND_URL}/auth/apple/start
# NEXT_PUBLIC_GOOGLE_AUTH_START_URL=http://localhost:5050/auth/google/start
# NEXT_PUBLIC_APPLE_AUTH_START_URL=http://localhost:5050/auth/apple/start

# Optional callback URLs used by social auth helper utilities.
# NEXT_PUBLIC_GOOGLE_AUTH_CALLBACK_URL=http://localhost:3000/auth/google/callback
# NEXT_PUBLIC_APPLE_AUTH_CALLBACK_URL=http://localhost:3000/auth/apple/callback
