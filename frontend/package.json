{
  "name": "mutuity-frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "graphql:schema": "graphql-codegen --config codegen.schema.cjs",
    "graphql:codegen": "graphql-codegen --config codegen.cjs",
    "graphql:check": "npm run graphql:schema && npm run graphql:codegen",
    "typecheck": "npm run graphql:check && tsc --noEmit -p tsconfig.json",
    "lint": "next lint",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.18.0",
    "@mui/material": "^5.15.15",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "formik": "^2.4.9",
    "graphql": "^16.13.2",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "isomorphic-dompurify": "^3.11.0",
    "next": "^14.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.4",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/schema-ast": "^5.0.2",
    "@graphql-codegen/typed-document-node": "^6.1.8",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.3",
    "jest": "^29.7.0",
    "typescript": "^5.4.5"
  }
}
