NODE_ENV=development
BACKEND_PORT=5050
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mutuity
PG_DEFAULT_ROLE=anonymous
GRAPHILE_SCHEMA=app_public
GRAPHILE_EXTENDED_ERRORS=hint,detail,errcode
BACKEND_CORS_ORIGINS=http://localhost:3000
ALLOW_GRAPHIQL=true
POSTGRAPHILE_WATCH_PG=true
SESSION_SECRET=change-me-for-production
SESSION_COOKIE_NAME=mutuity_session
SESSION_TTL_HOURS=168
PASSWORD_HASH_ROUNDS=12
LOGIN_RATE_LIMIT_WINDOW_MS=300000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
ALLOW_DEV_AUTH_HEADERS=true
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL=2000
MAIL_DELIVERY_ENABLED=false
MAIL_WEB_APP_URL=http://localhost:3000
MAIL_PRODUCT_NAME=Mutuity
MAIL_FROM_ADDRESS=Mutuity <noreply@mutuity.local>
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_API_URL=

# Social auth (Google OAuth start route)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=
GOOGLE_OAUTH_SCOPES=openid email profile
SOCIAL_AUTH_STATE_SECRET=

# Apple start endpoint remains URL-based until Apple callback implementation lands
APPLE_AUTH_START_URL=
# Compatibility fallback for Apple only: NEXT_PUBLIC_APPLE_AUTH_START_URL

# Optional frontend base URL for auth redirects and generated links
FRONTEND_URL=http://localhost:3000
