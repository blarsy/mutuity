# Copy this file to .env.prod and fill in real secrets.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mutuity

# Public URLs and CORS
FRONTEND_URL=https://app.example.com
BACKEND_CORS_ORIGINS=https://app.example.com

# Backend auth hardening
SESSION_SECRET=change-me-long-random-string
SOCIAL_AUTH_STATE_SECRET=change-me-long-random-string
SESSION_COOKIE_NAME=mutuity_session
SESSION_TTL_HOURS=168
ALLOW_DEV_AUTH_HEADERS=false

# Backend runtime
PASSWORD_HASH_ROUNDS=12
LOGIN_RATE_LIMIT_WINDOW_MS=300000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# Mail delivery
MAIL_DELIVERY_ENABLED=true
MAIL_WEB_APP_URL=https://app.example.com
MAIL_PRODUCT_NAME=Mutuity
MAIL_FROM_ADDRESS=Mutuity <noreply@example.com>
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_API_URL=https://api.mailgun.net

# Worker
WORKER_CONCURRENCY=5
WORKER_POLL_INTERVAL=2000

# Frontend public config
NEXT_PUBLIC_GRAPHQL_URL=https://api.example.com/graphql
NEXT_PUBLIC_GRAPHQL_WS_URL=wss://api.example.com/graphql
NEXT_PUBLIC_BACKEND_URL=https://api.example.com
NEXT_PUBLIC_DEFAULT_LOCALE=fr

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CALLBACK_URL=https://api.example.com/auth/google/callback
GOOGLE_OAUTH_SCOPES=openid email profile

# Apple OAuth
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
# Keep newline escapes (\n) if storing the private key on one line.
APPLE_OAUTH_PRIVATE_KEY=
APPLE_OAUTH_CALLBACK_URL=https://api.example.com/auth/apple/callback
