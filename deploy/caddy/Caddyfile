{
  email topela.tech@gmail.com
}

app.test.topela.com {
  encode zstd gzip

  @staticAssets {
    path /_next/* /favicon.ico /robots.txt /sitemap.xml
  }
  header @staticAssets Cache-Control "public, max-age=31536000, immutable"

  reverse_proxy frontend:3000
}

api.test.topela.com {
  encode zstd gzip

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }

  @graphql {
    path /graphql
  }

  reverse_proxy @graphql backend:5050 {
    # Caddy forwards Upgrade/Connection headers automatically; this keeps GraphQL WS working.
    flush_interval -1
  }

  reverse_proxy backend:5050
}
