{
  "name": "mutuity",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm --workspace backend run dev",
    "dev:worker": "npm --workspace backend run worker",
    "dev:frontend": "npm --workspace frontend run dev",
    "db:migrate": "bash ./database/migrate.sh",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:migrate": "docker compose run --rm migrate",
    "guard:sql-boundary": "node ./scripts/check-sql-boundary.mjs",
    "guard:sql-plpgsql": "bash ./scripts/check-plpgsql-quality.sh",
    "e2e:seed": "node ./e2e/scripts/seed-smoke-users.mjs",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:full": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:sanity": "bash ./e2e/scripts/run-smoke-sanity.sh",
    "typecheck": "npm --workspace backend run typecheck && npm --workspace frontend run typecheck",
    "lint": "npm --workspace backend run lint && npm --workspace frontend run lint",
    "test": "npm --workspace backend run test && npm --workspace frontend run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
